{
    "grpo_loss_type": "logprob",
    "logprob_num_steps": 5,
    "logprob_t_start": 0.01,
    "logprob_discount": 0.8,
    "logprob_min_std": 0.1,
    "il_loss_weight": 0.0,
    "il_adaptive": false,

    "num_generations": 16,
    "train_epochs": 15,
    "inner_epochs": 1,
    "learning_rate": 0.0003,
    "grad_accum_groups": 2,

    "noise_scale_range": [0.5, 2.0],
    "rejection_keep": 0,

    "advantage_mode": "normalized",
    "kl_coef": 0.0,

    "w_safety": 5.0,
    "w_progress": 1.0,
    "w_smooth": 0.5,
    "w_feasibility": 5.0,
    "w_centerline": 5.0,
    "rb_near_scale": 5.0,
    "rb_wide_scale": 0.5,
    "enable_lane_departure": true,
    "lane_gate_enabled": true,
    "lane_near_scale": 50.0,
    "lane_wide_scale": 20.0,
    "lane_cont_scale": 10.0,
    "enable_overprogress": true,
    "overprogress_margin": 1.0,
    "overprogress_penalty": 3.0,
    "stopped_penalty": 100.0,
    "underprogress_penalty": 200.0,
    "underprogress_threshold": 0.5,
    "progress_norm_scale": 10.0,
    "reward_mode": "survival",
    "diffusion_k_steps": 8,

    "use_lora": true,
    "lora_rank": 16,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "lora_target": "all",
    "n_prob_scenes": 20,
    "n_normal_scenes": 0,
    "random_guidance_mode": "none"
